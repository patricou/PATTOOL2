# -----------------------------------------------------------------------------
# PatTool — local configuration template
#
# Copy this file to application.properties and adjust values.
# (application.properties is gitignored so secrets and LAN IPs are not committed.)
#
# If your application.properties was overwritten: in the IDE, right-click the file
# → Local History to restore an earlier version.
#
# AI assistant: see also application-assistant.example.properties to merge if needed.
# -----------------------------------------------------------------------------

spring.application.name=PATTOOL
server.port=8000

# --- MongoDB (adjust host / database for your environment) ---
spring.data.mongodb.host=localhost
spring.data.mongodb.port=27017
spring.data.mongodb.database=rando
# Alternative: spring.data.mongodb.uri=mongodb://user:pass@host:27017/rando

# --- Files / multipart ---
spring.servlet.multipart.max-file-size=100MB
spring.servlet.multipart.max-request-size=350MB
app.uploaddir=C:\\temp
file.storage.base-path=C:\\temp\\pattool-disk-images

app.imagemaxsizekb=500

# --- Keycloak (required for security) ---
keycloak.realm=pat-realm
keycloak.auth-server-url=http://localhost:8080/auth
keycloak.resource=tutorial-frontend
keycloak.credentials.secret=change-me-in-local-config
keycloak.bearer-only=true
keycloak.client-id=tutorial-frontend

# Allowed CORS origins for the API (browser)
app.cors.allowed-origins=http://localhost:4200,http://127.0.0.1:4200,http://localhost:8000,http://127.0.0.1:8000

# --- Page « Monde → Sécurité / périmètre » : liens optionnels (JWT requis pour lecture API)
# Tableau de bord scanner interne (ZAP/Burp/etc.), vide si non utilisé.
pat.security-awareness.scanner-dashboard-url=
# Runbook ou wiki sécurité interne.
pat.security-awareness.internal-runbook-url=

# --- Sonde HTTP passive (Monde/Maison → scan sécurité, onglet tests)
pat.passive-probe.allow-private-targets=false
pat.passive-probe.max-redirects=5
pat.passive-probe.connect-timeout-seconds=5
pat.passive-probe.request-timeout-seconds=15

# --- App mail (MailController requires these keys) ---
app.mailsentfrom=
app.mailsentto=
app.sendmail=false

# --- OpenAI assistant ---
openai.api=https://api.openai.com/v1/chat/completions
openai.key=
openai.assistant.model=gpt-4o-mini
openai.assistant.max-tokens=8192
# Délais connexion et lecture HTTP vers l’API OpenAI (billing, liste modèles, chat assistant).
openai.http.connect-timeout-seconds=300
openai.http.read-timeout-seconds=300
openai.billing.credit-grants-url=https://api.openai.com/v1/dashboard/billing/credit_grants

# --- Assistant Anthropic, Google Gemini & Mistral (timeouts HTTP dédiés côté serveur ; voir application-assistant.example.properties pour les clés API) ---
anthropic.http.connect-timeout-seconds=300
anthropic.http.read-timeout-seconds=300
gemini.http.connect-timeout-seconds=300
gemini.http.read-timeout-seconds=300
mistral.http.connect-timeout-seconds=300
mistral.http.read-timeout-seconds=300

# Globe proxy (/api/external/globe) — téléchargements images / GeoJSON / ISS (délais plus longs que le RestTemplate générique).
globe.proxy.http.connect-timeout-seconds=10
globe.proxy.http.read-timeout-seconds=90

# ISS ground track stored in MongoDB while the globe overlay is active (world-globe page).
# Retention window for historical trace (default 30 days ≈ 1 month).
globe.iss.trace.retention.days=30
# Minimum seconds between two stored ISS samples (default 60 = 1 minute).
globe.iss.trace.sample-interval.seconds=60
# Max points returned to the globe for rendering (uniform decimation if more samples exist).
globe.iss.trace.max-display-points=8000
# Background ISS sampling (server scheduler, no users on globe required). Flag persisted in MongoDB appParameters.
globe.iss.trace.background.enabled-default=false
globe.iss.trace.background.interval.seconds=900
globe.iss.trace.background.fixed-rate-ms=900000

# --- IoT gate / ESP (HomeIOTService beans: no defaults in code) ---
app.arduino.ip=192.168.1.65
app.esp32.1.ip=192.168.1.71

# --- Weather (optional) ---
openweathermap.api.key=
# Météo-France DPRadar — https://portail-api.meteofrance.fr
# 1) Subscribe to API « Données Publiques Radar » (not « Radar Package »)
# 2) Configure the API → Token type « API Key » → Generate Token → paste below (NOT the consumer key/secret)
# Jeton API Key pour DPRadar (API « Données Publiques Radar »)
meteofrance.api.token=
# Jeton API Key pour DPClim (API « Données Climatologiques ») — clé distincte du radar
# meteofrance.clim.api.token=
# Jeton API Key pour DPObs v2 (API « Données Publiques Observation ») — températures temps réel sur la carte
# meteofrance.obs.api.token=
# meteofrance.obs.base.url=https://public-api.meteofrance.fr/public/DPObs/v2
# Jeton API Key pour AROME-PI (API « AROMEPI 1.0 ») — prévisions nowcasting 0–6 h + cartes WMS animées
# meteofrance.aromepi.api.token=
# meteofrance.aromepi.base.url=https://public-api.meteofrance.fr/public/aromepi/1.0
# meteofrance.aromepi.wms.service=MF-NWP-HIGHRES-AROMEPI-001-FRANCE-WMS
# meteofrance.aromepi.wms.max.concurrent=4
# Alternative: OAuth application id (Base64 string shown as « Application ID » in the portal)
# meteofrance.oauth.application-id=
# meteofrance.radar.base.url=https://public-api.meteofrance.fr/public/DPRadar/v1
# meteofrance.radar.wms.url=https://geoservices.meteofrance.fr/services/WMS
# meteofrance.radar.wms.layer=RADARURANCE400M
# WMS geoservices (optional — DPRadar /produit is HDF5, not PNG; no public MF radar WMS by default)
# meteofrance.radar.wms.enabled=false
# Intervalle de rafraîchissement auto de la couche radar sur la page Météo France (secondes, 30–600, défaut 60)
# meteofrance.radar.refresh.seconds=60
# meteofrance.temperature.cache.minutes=5
# API Données Climatologiques (DPClim v1) — même jeton si abonné sur le portail
# meteofrance.clim.base.url=https://public-api.meteofrance.fr/public/DPClim/v1

# --- Loto import (draw archives) ---
loto.archive.base-url=https://www.lesbonsnumeros.com

# EuroMillions : répertoire sur le SERVEUR contenant les CSV FDJ (*.csv à importer via POST /api/euromillions/sync).
# exemple Windows : euromillions.import.directory=C:/Users/desch/Downloads/euromillions
euromillions.import.directory=
# Téléchargement auto fdj.fr → POST /api/euromillions/fdj-archive/import (admin) : page HTML + attribut download du ZIP « février 2020 »
euromillions.fdj.historique-url=https://www.fdj.fr/jeux-de-tirage/euromillions-my-million/historique
euromillions.fdj.archive-download-attribute=euromillions_202002
# Borne basse (ISO yyyy-MM-dd) des tirages dans le JSON assistant pat-eurom-ai-v2.
# Fallback si aucune entrée Mongo appParameters sous la même clé n’est définie (admin peut PATCH /api/euromillions/client-settings pour persister).
euromillions.ai.min-draw-date=2020-01-01

# --- CERN external APIs (proxy /api/external/cern/*) ---
# Open Data: https://opendata.cern.ch/api
# CDS Repository (InvenioRDM): https://repository.cern/api  — not repository.cern.ch
# app.cern.opendata-api-base=https://opendata.cern.ch/api
# app.cern.repository-api-base=https://repository.cern/api
# app.cern.zenodo-api-base=https://zenodo.org/api

# --- Flight tracking (OpenSky Network, proxy /api/external/globe/flight/*) ---
# OpenSky uses OAuth2 client credentials (strongly recommended — anonymous quota is very low).
# Create an API client at https://opensky-network.org/my-opensky/account and set:
# opensky.client-id=your-client-id
# opensky.client-secret=your-client-secret
# Without credentials, callsign search uses states/all (~1 request / 10 s) and may return 502 when rate-limited.
# opensky.base-url=https://opensky-network.org/api
# opensky.token-url=https://auth.opensky-network.org/auth/realms/opensky-network/protocol/openid-connect/token
opensky.client-id=
opensky.client-secret=
# Cache (s) for the full states/all snapshot used for callsign search (default 30, minimum 10).
# opensky.all-states-cache-seconds=30
# Reuse stale snapshot up to N seconds when OpenSky returns 429 (default 900 = 15 min).
# opensky.all-states-stale-max-seconds=900

# --- Flight route enrichment (adsbdb.com, no API key) ---
# When OpenSky omits estArrivalAirport during a live flight:
# 1) retry OpenSky /flights/departure from the known departure airport + callsign
# 2) fallback adsbdb only if its planned origin matches the live OpenSky departure
# flight.adsbdb.enabled=true
# flight.adsbdb.base-url=https://api.adsbdb.com/v0

# --- Chemistry external APIs (proxy /api/external/chem/*) ---
# PubChem PUG REST (no API key required, public data): periodic table, molecules, 2D images, autocomplete
# app.chem.pubchem-rest-base=https://pubchem.ncbi.nlm.nih.gov/rest/pug
# app.chem.pubchem-autocomplete-base=https://pubchem.ncbi.nlm.nih.gov/rest/autocomplete

# --- Stellarium Web (proxy /api/external/stellarium/*) ---
# Sky map iframe + Noctua Sky catalogue (api.noctuasky.com), geolocation via backend only.
# app.stellarium.web-base=https://stellarium-web.org
# app.stellarium.noctuasky-api-base=https://api.noctuasky.com/api/v1
# app.stellarium.freegeoip-base=https://freegeoip.stellarium.org
# Optional override when behind a reverse proxy (public URL of the viewer endpoint):
# app.stellarium.patool-viewer-base=https://www.example.com/api/external/stellarium/viewer

# --- Image cache (PatToolApplication) ---
app.cache.persistence.restore-on-startup=true

# --- CoinGecko (Cryptos page, proxy /api/external/crypto/*) ---
# Demo (free): app.coingecko.plan=demo + header x-cg-demo-api-key
# Pro (paid):  app.coingecko.plan=pro  → https://pro-api.coingecko.com/api/v3 + x-cg-pro-api-key
# app.coingecko.api-base=https://api.coingecko.com/api/v3
# app.coingecko.api-key=
# app.coingecko.plan=demo
